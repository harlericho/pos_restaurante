; ===========================
; Configuración de base de datos
; ===========================
; Copia este archivo como config.ini y completa los valores reales.
; NUNCA subas config.ini a git (está en .gitignore).

DB_HOST = "localhost"            ;servidor de base de datos
DB_NAME = "db_pos_restaurante"   ;nombre de la base de datos
DB_USER = "root"                 ;usuario de la base de datos
DB_PASS = ""                     ;contraseña de la base de datos
DB_PORT = 3306                   ;puerto de la base de datos
